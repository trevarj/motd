<?xml version="1.0" encoding="utf-8"?>
<!-- Legacy (Android 11 and lower) backup policy. Credentials live in Room's database domain
     and Preferences DataStore's files/datastore directory; neither may leave the device. -->
<full-backup-content>
    <exclude domain="database" path="." />
    <exclude domain="file" path="datastore/" />
    <exclude domain="device_database" path="." />
    <exclude domain="device_file" path="datastore/" />
</full-backup-content>
