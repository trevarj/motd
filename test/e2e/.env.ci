# test/e2e/.env.ci — committed config for the HERMETIC CI e2e run.
#
# These are EPHEMERAL LOCAL credentials for the self-contained bouncer stack in
# test/e2e/hermetic/ (ergo + soju via docker compose). They are NOT secrets and
# never touch an external network.
#
# The e2e workflow copies this file to test/e2e/.env (which runbook.sh sources),
# so no code change is needed. The Android emulator reaches host-published
# services at 10.0.2.2, so the app connects to soju at 10.0.2.2:6697.

# App under test — the debuggable E2E build keeps the .debug id but strips arm64-only JNI so it
# installs on the hermetic x86_64 emulator. It never exercises embedded obfuscation.
MOTD_PKG=io.github.trevarj.motd.debug
MOTD_APK=app/build/outputs/apk/e2e/app-e2e.apk

# soju bouncer (hermetic stack, published on the host at :6697; emulator=10.0.2.2).
MOTD_SOJU_HOST=10.0.2.2
MOTD_SOJU_PORT=6697
MOTD_SOJU_USER=motd
MOTD_SOJU_PASS=motdtest
MOTD_NICK=motdadb
MOTD_TEST_CHANNEL=##motdtest

# Second identity present in ##motdtest (seeded by the stack). Enables the
# nick-autocomplete / member-list steps in Phase C/D.
MOTD_SECOND_NICK=motdadb2

# Run only the phases that are green hermetically by default. Override in the
# workflow (or locally) to widen coverage: E2E_PHASES="a b c d e f g h i".
E2E_PHASES="a b c"
