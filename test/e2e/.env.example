# test/e2e/.env.example — copy to test/e2e/.env (gitignored) and fill in.
# Real values are secrets; never commit .env.

# App under test.
MOTD_PKG=io.github.trevarj.motd.debug
# Absolute path to the built debug APK (for clean install). If the app is
# already installed you may leave this blank.
MOTD_APK=

# soju test bouncer (see plans/18-e2e-runbook.md §0).
MOTD_SOJU_HOST=104.168.59.26
MOTD_SOJU_PORT=6697
MOTD_SOJU_USER=motd
MOTD_SOJU_PASS=changeme
MOTD_NICK=motdadb
MOTD_TEST_CHANNEL=##motdtest

# Optional second identity that seeds/messages the channel. When set, the
# DM/mention/typing and nick-autocomplete steps run; otherwise they are skipped.
MOTD_SECOND_NICK=motdadb2

# Optional device pin (needed only when multiple devices are attached).
# SERIAL=

# Optional seed overrides (fixtures/seed.sh); default to the SOJU_* values.
# MOTD_SEED_USER=motd
# MOTD_SEED_PASS=changeme
# MOTD_TARGET_NICK=motdadb

# Optional: restrict which phases run, space-separated (default: all).
# E2E_PHASES="a b c"
