# Local physical-device defaults for test/e2e/local-stack.sh.
# Copy to test/e2e/.env (gitignored). These are ephemeral local fixture
# credentials, not production secrets.

MOTD_PKG=io.github.trevarj.motd.debug
MOTD_APK=app/build/outputs/apk/foss/debug/app-foss-debug.apk

# local-stack.sh installs adb reverse tcp:6697, so the device uses loopback.
MOTD_SOJU_HOST=127.0.0.1
MOTD_SOJU_PORT=6697
MOTD_SOJU_USER=motd
MOTD_SOJU_PASS=motdtest
MOTD_NICK=motdadb
MOTD_TEST_CHANNEL=##motdtest
MOTD_SECOND_NICK=motdadb2

# Set when more than one device/emulator is attached.
# SERIAL=

# Restrict phases when iterating; the default is all phases.
# E2E_PHASES="a b c"

# For a different bouncer, override the values above only in the ignored .env.
# Seed overrides default to the same SOJU credentials.
# MOTD_SEED_USER=
# MOTD_SEED_PASS=
# MOTD_TARGET_NICK=
