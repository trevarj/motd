# Canonical non-secret fixture configuration for the fast Kotlin journeys and reconnect window.
: "${FAST_E2E_ANNOTATION:=io.github.trevarj.motd.FastHeadlessE2e}"
: "${FAST_E2E_TARGET_PACKAGE:=io.github.trevarj.motd.debug}"
: "${FAST_E2E_SOJU_HOST:=10.0.2.2}"
: "${FAST_E2E_SOJU_PORT:=6697}"
: "${FAST_E2E_SOJU_USER:=motd}"
: "${FAST_E2E_SOJU_PASSWORD:=motdtest}"
: "${FAST_E2E_NICK:=motdadb}"
: "${FAST_E2E_CHANNEL:=##motdtest}"
: "${FAST_E2E_SECOND_NICK:=motdadb2}"
: "${FAST_E2E_STACK_KIND:=hermetic}"
: "${FAST_E2E_NATIVE_STACK_DIR:=/tmp/motd-fast-suite-stack}"
: "${FAST_E2E_NATIVE_ERGO_PORT:=16667}"
: "${FAST_E2E_RECONNECT_TOKEN:=motd$(date +%s)}"
