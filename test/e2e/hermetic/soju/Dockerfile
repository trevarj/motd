# test/e2e/hermetic/soju/Dockerfile — build a pinned soju + sojuctl image.
#
# soju has no official published container image, so we build it from the pinned
# release tag. The runtime stage carries soju, sojuctl, and openssl (for the
# self-signed TLS cert generated by entrypoint.sh).
#
# Pinned versions (bump deliberately):
#   - Go builder:  golang:1.24-alpine3.21
#   - soju:        v0.10.1  (codeberg.org/emersion/soju)

FROM golang:1.24-alpine3.21 AS build
ARG SOJU_VERSION=v0.10.1
RUN apk add --no-cache git make build-base
WORKDIR /src
# Fetch the pinned tag only (shallow) for a reproducible, fast build.
RUN git clone --depth 1 --branch "${SOJU_VERSION}" https://codeberg.org/emersion/soju.git .
# Build soju, sojuctl and sojudb. GOFLAGS pins module verification off-network
# is unnecessary; the tag's go.sum is authoritative.
RUN go build -o /out/soju    ./cmd/soju \
 && go build -o /out/sojuctl ./cmd/sojuctl \
 && go build -o /out/sojudb  ./cmd/sojudb

FROM alpine:3.21
RUN apk add --no-cache ca-certificates openssl sqlite-libs
COPY --from=build /out/soju    /usr/local/bin/soju
COPY --from=build /out/sojuctl /usr/local/bin/sojuctl
COPY --from=build /out/sojudb  /usr/local/bin/sojudb
RUN mkdir -p /var/lib/soju /etc/soju/tls
COPY soju.config   /etc/soju/soju.config
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh
EXPOSE 6697
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
