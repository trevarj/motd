# test/e2e/hermetic/soju/soju.config — hermetic soju bouncer for the MOTD e2e run.
#
# This is the endpoint the APP connects to (via the emulator at 10.0.2.2:6697).
# It presents a self-signed TLS cert (generated at container start); the app's
# TOFU CertTrustDialog handles the "Trust this certificate?" prompt in Phase A.
#
# soju proxies the ergo upstream and exposes it to the app as a bouncer network
# named "libera" (the name Phase A expects to import). The message-store is `db`
# (sqlite FTS) so CHATHISTORY replays real messages to the app — the history
# backfill assertion in Phase C depends on this being persistent, NOT memory.

# Hostname advertised to clients. Matches the self-signed cert CN.
hostname localhost

# Persistent account/network state in sqlite. Bind-mounted so it survives a
# `docker compose restart` but is wiped by `down -v` between fresh CI runs.
db sqlite3 /var/lib/soju/soju.db

# Persistent message store in the DB (FTS-indexed). REQUIRED for CHATHISTORY /
# search / the Phase C history-backfill assertion. `memory` would drop history
# on restart and disable chathistory; `fs` discards message tags. `db` keeps
# both, so the app can page real backfilled messages.
message-store db

# App-facing TLS listener. Self-signed cert/key generated by the entrypoint.
listen ircs://:6697
tls /etc/soju/tls/cert.pem /etc/soju/tls/key.pem

# Admin socket for sojuctl (user/network provisioning + seeding). Unix socket
# inside the container only.
listen unix+admin:///var/lib/soju/admin.sock

# Advertise the message-tags / server-time / batch / chathistory caps the app
# uses. soju enables the relevant IRCv3 extensions by default; no extra keys
# needed here.
